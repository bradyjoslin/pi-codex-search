{
  "name": "pi-codex-search",
  "version": "0.1.0",
  "description": "Pi extension for Codex Web Search — reuse your ChatGPT Plus/Pro Codex subscription in pi-coding-agent",
  "keywords": [
    "chatgpt",
    "chatgpt-plus",
    "chatgpt-pro",
    "codex",
    "coding-agent",
    "oauth",
    "openai",
    "openai-codex",
    "pi",
    "pi-coding-agent",
    "pi-extension",
    "pi-mono",
    "pi-package",
    "responses-api",
    "subscription",
    "tool-extension",
    "web-search",
    "web_search"
  ],
  "bugs": {
    "url": "https://github.com/Leechael/pi-codex-search/issues"
  },
  "license": "MIT",
  "author": "Leechael",
  "repository": {
    "type": "git",
    "url": "https://github.com/Leechael/pi-codex-search"
  },
  "files": [
    "index.ts",
    "src",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "scripts": {
    "clean": "echo 'nothing to clean'",
    "build": "echo 'nothing to build'",
    "check": "tsc --noEmit",
    "test": "node --test tests/*.test.ts",
    "lint": "oxlint .",
    "format": "oxfmt . --write",
    "format:check": "oxfmt . --check",
    "pre-commit": "prek run"
  },
  "devDependencies": {
    "@j178/prek": "^0.3.8",
    "@types/node": "^24.0.0",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "typescript": "^5.9.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  }
}
